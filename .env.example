# Copy to `.env` and fill in real values. `.env` is gitignored.

# ── Auth (nuxt-auth-utils) ─────────────────────────────────────────
# Secret for the sealed session cookie. MUST be >= 32 characters.
NUXT_SESSION_PASSWORD=dev-session-password-change-me-min-32-chars

# Discord OAuth (code flow). Redirect URI to register on the Discord
# app: https://ihatemy.live/auth/discord
NUXT_OAUTH_DISCORD_CLIENT_ID=dummy-discord-client-id
NUXT_OAUTH_DISCORD_CLIENT_SECRET=dummy-discord-client-secret

# Xbox / Microsoft OAuth (Minecraft account linking). Uses nuxt-auth-utils'
# Microsoft provider on the consumer endpoint. The Azure app registration must
# be "Personal Microsoft accounts only". Redirect URI: https://ihatemy.live/auth/xbox
NUXT_OAUTH_MICROSOFT_CLIENT_ID=dummy-microsoft-client-id
NUXT_OAUTH_MICROSOFT_CLIENT_SECRET=dummy-microsoft-client-secret
NUXT_OAUTH_MICROSOFT_TENANT=consumers

# ── PenguBot server-to-server signing ──────────────────────────────
# Shared secret used to HMAC-sign requests from this server to PenguBot,
# so PenguBot can prove a request came from the website and not a user.
# MUST match the value configured on PenguBot. Use a long random secret.
# A value starting with "dummy" keeps dev on stub responses.
NUXT_PENGU_SIGNING_KEY=dummy-pengu-signing-key
# Identifies which signing key is in use, to allow zero-downtime rotation.
NUXT_PENGU_SIGNING_KEY_ID=v1

# ── Nuxt Studio (self-hosted docs editor at /_studio) ──────────────
# Authentication uses a custom OIDC/SSO provider — the production
# Authentik instance. Studio enables SSO login when these are set.
# Standard OIDC endpoints are derived from the server URL:
#   <STUDIO_SSO_URL>/oauth/authorize | /oauth/token | /oauth/userinfo
STUDIO_SSO_URL=https://authentik.example/application/o/pengu-docs
STUDIO_SSO_CLIENT_ID=
STUDIO_SSO_CLIENT_SECRET=
# Must match the redirect URI registered on the Authentik OIDC app.
STUDIO_SSO_REDIRECT_URL=https://ihatemy.live/_studio/auth/sso

# OIDC authenticates the person but does not grant GitHub access, so
# commits are pushed with a service GitHub Personal Access Token
# (repo scope) for ThePenguinsGit/ihatemy.live.
STUDIO_GITHUB_TOKEN=
